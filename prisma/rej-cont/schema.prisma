generator rejContClient {
  provider   = "prisma-client-js"
  output     = "../../node_modules/.prisma/rej-cont-client"
  engineType = "client"
}

datasource rejContDb {
  provider = "postgresql"
}

model Container {
  id              Int       @id @default(autoincrement())
  number          String    @rejContDb.VarChar(30)
  mrn             String?   @rejContDb.VarChar(40)
  stop            String?   @rejContDb.VarChar(255)
  lastRefreshTime DateTime  @default(now()) @rejContDb.Timestamp(0)
  status          String?   @rejContDb.VarChar(30)
  terminalName    Terminal?
  createdAt       DateTime  @default(now()) @rejContDb.Timestamp(0)
}

enum Terminal {
  BCT
  DCT
  GCT
}
